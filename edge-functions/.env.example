# Edge Functions Environment Variables
# Copy to .env and fill in values

# Supabase connection (internal Docker network URL)
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
JWT_SECRET=your-jwt-secret-here

# APNs Push Notifications (from Apple Developer portal)
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_PRIVATE_KEY=base64-encoded-p8-key
APNS_ENVIRONMENT=development    # or "production"

# CORS (restrict to your domain)
ALLOWED_ORIGIN=https://wellvo.net

# Server port
PORT=9000

# Twilio SMS (optional, for escalation SMS fallback)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
